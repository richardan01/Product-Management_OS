DISCORD_TOKEN=your_discord_bot_token_here
NOTIFICATION_CHANNEL_ID=your_discord_channel_id_here

# Optional: override claude binary path (default: searches PATH for 'claude')
# CLAUDE_BIN=/path/to/your/claude

# Optional: standup notification time (24-hour format, default: 9 = 9:00 AM)
# STANDUP_HOUR=9
# STANDUP_MINUTE=0

# Optional: timezone for standup (default: UTC)
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones for valid values
# TIMEZONE=America/New_York
# TIMEZONE=Asia/Singapore
# TIMEZONE=Europe/London
